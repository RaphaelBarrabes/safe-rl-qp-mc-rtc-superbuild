{
    "version": 10,
    "$schema": "https://cmake.org/cmake/help/latest/_downloads/3e2d73bff478d88a7de0de736ba5e361/schema.json",
    "configurePresets": [
        {
            "name": "relwithdebinfo",
            "displayName": "RelWithDebInfo",
            "generator": "Unix Makefiles",
            "binaryDir": "${sourceDir}/../build/superbuild",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "RelWithDebInfo",
                "SOURCE_DESTINATION": "${sourceDir}/../src",
                "BUILD_DESTINATION": "${sourceDir}/../build",
                "CMAKE_INSTALL_PREFIX": "${sourceDir}/../install"
            }
        },
        {
            "name": "relwithdebinfo-notests",
            "displayName": "RelWithDebInfo (no tests)",
            "inherits": [
                "relwithdebinfo"
            ],
            "cacheVariables": {
                "BUILD_TESTING": "OFF"
            }
        },
        {
            "name": "release",
            "inherits": [
                "relwithdebinfo"
            ],
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release"
            }
        },
        {
            "name": "release-notests",
            "inherits": [
                "relwithdebinfo-notests"
            ],
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release"
            }
        }
    ],
    "buildPresets": [
        {
            "name": "relwithdebinfo",
            "displayName": "RelWithDebInfo",
            "configurePreset": "relwithdebinfo",
            "configuration": "RelWithDebInfo",
            "targets": [
                "install"
            ]
        },
        {
            "name": "relwithdebinfo-notests",
            "displayName": "RelWithDebInfo (no tests)",
            "configurePreset": "relwithdebinfo-notests",
            "configuration": "RelWithDebInfo",
            "targets": [
                "install"
            ]
        },
        {
            "name": "release",
            "displayName": "Release",
            "configurePreset": "release",
            "configuration": "Release",
            "targets": [
                "install"
            ]
        },
        {
            "name": "release-notests",
            "displayName": "Release (no tests)",
            "configurePreset": "release-notests",
            "configuration": "Release",
            "targets": [
                "install"
            ]
        }
    ]
}
